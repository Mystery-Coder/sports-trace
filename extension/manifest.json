{
  "manifest_version": 3,
  "name": "SportTrace Anti-Piracy Scanner",
  "version": "1.0.0",
  "description": "Detect invisible watermark DNA in images and videos on any webpage. Fires detection pings and enforcement actions to Firestore.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
